/**
 * Represents an archived expense.
 *
 * The original Expense model remains unchanged to preserve
 * compatibility with the FinancialEngine and existing features.
 */
export interface ArchivedExpense {
  /** Same ID as the original expense */
  id: string;

  /** Original expense (immutable) */
  expense: Expense;

  /** Date when the expense was archived */
  archivedAt: Date;

  /** Reason for archiving */
  reason: 'user_deleted' | 'correction';
}
